# ==========================================
# collection/display
# 採集ポイント上の表示更新
# ==========================================

# ---------- OAK ----------
execute as @e[type=minecraft:armor_stand,tag=collection_display,tag=collection_oak] at @s if entity @e[type=minecraft:interaction,tag=collection_oak,tag=collection_active,distance=..1.0] run scoreboard players set #tool collection_power 0
execute as @e[type=minecraft:armor_stand,tag=collection_display,tag=collection_oak] at @s if entity @e[type=minecraft:interaction,tag=collection_oak,tag=collection_active,distance=..1.0] as @a[distance=..5] if items entity @s weapon.mainhand #minecraft:axes run scoreboard players set #tool collection_power 1
execute as @e[type=minecraft:armor_stand,tag=collection_display,tag=collection_oak] at @s if entity @e[type=minecraft:interaction,tag=collection_oak,tag=collection_active,distance=..1.0] if score #tool collection_power matches 0 unless data entity @s {CustomName:'{"text":"ツールが間違っています","color":"dark_red"}'} run data modify entity @s CustomName set value '{"text":"ツールが間違っています","color":"dark_red"}'
execute as @e[type=minecraft:armor_stand,tag=collection_display,tag=collection_oak] at @s if score #tool collection_power matches 1 if entity @e[type=minecraft:interaction,tag=collection_oak,tag=collection_active,distance=..1.0,scores={collection_hp=3}] unless data entity @s {CustomName:'{"text":"HP 3/3","color":"green"}'} run data modify entity @s CustomName set value '{"text":"HP 3/3","color":"green"}'
execute as @e[type=minecraft:armor_stand,tag=collection_display,tag=collection_oak] at @s if score #tool collection_power matches 1 if entity @e[type=minecraft:interaction,tag=collection_oak,tag=collection_active,distance=..1.0,scores={collection_hp=2}] unless data entity @s {CustomName:'{"text":"HP 2/3","color":"yellow"}'} run data modify entity @s CustomName set value '{"text":"HP 2/3","color":"yellow"}'
execute as @e[type=minecraft:armor_stand,tag=collection_display,tag=collection_oak] at @s if score #tool collection_power matches 1 if entity @e[type=minecraft:interaction,tag=collection_oak,tag=collection_active,distance=..1.0,scores={collection_hp=1}] unless data entity @s {CustomName:'{"text":"HP 1/3","color":"red"}'} run data modify entity @s CustomName set value '{"text":"HP 1/3","color":"red"}'

